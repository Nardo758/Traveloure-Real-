# Traveloure Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# API Configuration
# ============================================
# Backend API Base URL (REQUIRED)
# Development: http://localhost:8000
# Production: https://your-api-domain.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ============================================
# NextAuth Configuration
# ============================================
# NextAuth URL (REQUIRED for production)
NEXTAUTH_URL=http://localhost:3000

# NextAuth Secret (REQUIRED - generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-here

# ============================================
# Google OAuth (Optional - for social login)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Facebook OAuth (Optional - for social login)
# ============================================
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# ============================================
# Google Maps API (Required for map features)
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# Environment
# ============================================
# Options: development | production
NODE_ENV=development

# ============================================
# Notes:
# ============================================
# 1. Never commit .env.local to version control
# 2. All NEXT_PUBLIC_* variables are exposed to the browser
# 3. Keep sensitive keys (secrets, tokens) without NEXT_PUBLIC_ prefix
# 4. Rotate API keys regularly for security
# 5. Use restricted API keys in production (domain/IP restrictions)
