# Database
DATABASE_URL=postgresql://user:password@localhost:5432/traveloure

# Auth
REPLIT_DEPLOYMENT=1
# REPLIT_DB_URL is automatically set by Replit

# API Keys - External Services

# Google Maps & Places API (Required for venue search)
# Get your API key: https://console.cloud.google.com/apis/credentials
# Enable: Places API, Maps JavaScript API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# SERP API (Optional - for additional search results)
# Get your API key: https://serpapi.com/
SERP_API_KEY=your_serp_api_key_here

# AI Services
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROK_API_KEY=your_grok_api_key_here

# Travel APIs
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
VIATOR_API_KEY=your_viator_api_key_here

# Optional Services
PEXELS_API_KEY=your_pexels_api_key_here
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
FEVER_API_KEY=your_fever_api_key_here

# Facebook OAuth (Optional)
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_REDIRECT_URI=http://localhost:5000/api/auth/facebook/callback

# Server Configuration
PORT=5000
NODE_ENV=development

# Playwright / Automated Testing
# Set RATE_LIMIT_BYPASS_KEY to bypass all rate limiters during tests.
# The real value is in Replit Secrets. When running tests locally against the live app:
#   RATE_LIMIT_BYPASS_KEY=<key> BASE_URL=https://<your-replit-url>.replit.dev npx playwright test
# Or add to your local .env file (never commit the real value).
RATE_LIMIT_BYPASS_KEY=your_test_bypass_key_here

# Target URL for Playwright tests (defaults to http://localhost:5000)
BASE_URL=http://localhost:5000
